---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-SG', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Blog — ROI Tools">
  <header class="mb-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900">Blog</h1>
    <p class="text-sm sm:text-base text-slate-600 mt-1">
      Notes on energy decisions in Singapore homes &mdash; ROI math, tariff watch, deep dives.
    </p>
  </header>

  {posts.length === 0 ? (
    <p class="text-sm text-slate-500">No posts yet. Check back soon.</p>
  ) : (
    <ul class="space-y-4">
      {posts.map((p) => (
        <li class="bg-white rounded-2xl ring-1 ring-slate-200 hover:ring-teal-300 transition p-5">
          <a href={`/blog/${p.slug}/`} class="block">
            <h2 class="text-lg font-semibold text-slate-900 hover:text-teal-700">{p.data.title}</h2>
            <p class="text-xs text-slate-500 mt-1">
              {fmt(p.data.pubDate)}
              {p.data.tags.length > 0 && (
                <>
                  &nbsp;·&nbsp;
                  {p.data.tags.map((t, i) => (
                    <span class="text-teal-600">#{t}{i < p.data.tags.length - 1 ? ' ' : ''}</span>
                  ))}
                </>
              )}
            </p>
            {p.data.description && (
              <p class="text-sm text-slate-600 mt-2">{p.data.description}</p>
            )}
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
