---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();

const fmt = (d: Date) =>
  d.toLocaleDateString('en-SG', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title={`${post.data.title} — ROI Tools`} description={post.data.description}>
  <article class="prose prose-slate max-w-none">
    <header class="mb-6 not-prose">
      <h1 class="text-2xl sm:text-3xl font-bold text-slate-900">{post.data.title}</h1>
      <p class="text-xs text-slate-500 mt-1">
        Published {fmt(post.data.pubDate)}
        {post.data.updatedDate && <> &middot; updated {fmt(post.data.updatedDate)}</>}
        {post.data.tags.length > 0 && (
          <>
            &nbsp;·&nbsp;
            {post.data.tags.map((t, i) => (
              <span class="text-teal-600">#{t}{i < post.data.tags.length - 1 ? ' ' : ''}</span>
            ))}
          </>
        )}
      </p>
    </header>
    <div class="bg-white rounded-2xl ring-1 ring-slate-200 p-6 sm:p-8 text-slate-700 leading-relaxed [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-slate-900 [&_h2]:mt-6 [&_h2]:mb-3 [&_h3]:font-semibold [&_h3]:text-slate-900 [&_h3]:mt-4 [&_h3]:mb-2 [&_p]:my-3 [&_a]:text-teal-600 [&_a:hover]:underline [&_ul]:list-disc [&_ul]:list-inside [&_ul]:space-y-1 [&_ol]:list-decimal [&_ol]:list-inside [&_ol]:space-y-1 [&_code]:bg-slate-100 [&_code]:px-1 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm [&_pre]:bg-slate-900 [&_pre]:text-slate-100 [&_pre]:p-4 [&_pre]:rounded-lg [&_pre]:overflow-x-auto [&_pre>code]:bg-transparent [&_pre>code]:p-0">
      <Content />
    </div>
    <p class="text-xs text-slate-500 mt-6">
      <a href="/blog/" class="text-teal-600 hover:underline">← All posts</a>
    </p>
  </article>
</BaseLayout>
