---
import { CALCULATORS } from '../data/calculators';

const pathname = Astro.url.pathname;
const parts = pathname.split('/').filter(Boolean);
const calcSlug = parts[0] || '';
const calc = CALCULATORS.find((c) => c.slug === calcSlug);

let activePage = '';
if (calc && parts.length >= 2) {
  const last = parts[parts.length - 1].replace(/\.html$/, '');
  activePage = last === 'index' ? '' : last;
}

const show = !!calc && calc.pages.length > 1;
---

{show && (
  <nav id="subtabs" class="bg-white border-b border-slate-200 sticky top-14 z-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 flex gap-5 overflow-x-auto">
      {calc!.pages.map((p) => {
        const isActive = p.slug === activePage;
        const href = p.slug ? `/${calc!.slug}/${p.slug}/` : `/${calc!.slug}/`;
        const cls = isActive
          ? 'border-teal-600 text-teal-700'
          : 'border-transparent text-slate-600 hover:text-teal-600 hover:border-slate-300';
        return (
          <a
            href={href}
            class={`px-1 py-3 text-sm font-medium border-b-2 whitespace-nowrap transition ${cls}`}
          >
            {p.title}
          </a>
        );
      })}
    </div>
  </nav>
)}
